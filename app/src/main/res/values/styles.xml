<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Fullscreen, no title bar, navy status bar -->
    <style name="AppTheme" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">#002464</item>
        <item name="android:statusBarColor">#002464</item>
        <item name="android:navigationBarColor">#002464</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <!-- Splash screen theme (Android 12+) -->
    <style name="SplashTheme" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#002464</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="postSplashScreenTheme">@style/AppTheme</item>
    </style>
</resources>
